{
  "name": "@edusentinel/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "db:seed:workspace": "node --env-file=.env prisma/seed-workspace.mjs",
    "db:seed:catalog": "node --env-file=.env prisma/seed-catalog.mjs",
    "db:seed:org": "node --env-file=.env prisma/seed-org.mjs",
    "db:seed:hr": "node --env-file=.env prisma/seed-hr.mjs",
    "postinstall": "prisma generate && node scripts/migrate-on-vercel.mjs",
    "test:security": "tsx --env-file=.env scripts/test-phase21.mts",
    "audit:verify": "tsx --env-file=.env scripts/verify-audit.mts",
    "test:pipeline": "tsx --env-file=.env scripts/test-phase3.mts",
    "gen:signing-key": "node scripts/gen-signing-key.mjs",
    "test:content": "tsx --env-file=.env scripts/test-phase4.mts",
    "test:permissions": "tsx --env-file=.env scripts/test-phase5.mts",
    "test:data": "tsx --env-file=.env scripts/test-phase6.mts",
    "test:org": "tsx --env-file=.env scripts/test-phase65.mts",
    "test:invites": "tsx --env-file=.env scripts/test-phase7.mts",
    "test:hr": "tsx --env-file=.env scripts/test-phase8.mts",
    "test:support": "tsx --env-file=.env scripts/test-phase9.mts",
    "test:e2e": "tsx --env-file=.env scripts/e2e-phase5.mts",
    "mfa:enroll": "node --env-file=.env scripts/mfa-enroll.mjs"
  },
  "dependencies": {
    "@edusentinel/ui": "*",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-mdx-remote": "^6.0.0",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.30.0",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0"
  }
}
