# Copy to .env and fill in. Never commit .env.
DATABASE_URL="file:./dev.db"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_TRUST_HOST=true
# 32-byte base64 key for encrypting TOTP secrets (same generator as AUTH_SECRET)
MFA_ENC_KEY=""
# Public base URL used in verification/reset emails
APP_URL="http://localhost:3000"
# Optional: transactional email via Resend; without it, mails log to console
# RESEND_API_KEY=
# MAIL_FROM="EduSentinel AI <no-reply@edusentinel.ai>"

# Optional: founder bootstrap for `npm run db:seed`
# FOUNDER_EMAIL=
# FOUNDER_NAME=
# FOUNDER_PASSWORD=   (min. 10 characters)
