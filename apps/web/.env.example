# Copy to .env and fill in. Never commit .env.
DATABASE_URL="file:./dev.db"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_TRUST_HOST=true
# 32-byte base64 key for encrypting TOTP secrets (same generator as AUTH_SECRET)
MFA_ENC_KEY=""
# Public base URL used in verification/reset emails
APP_URL="http://localhost:3000"
# Optional: transactional email via Resend; without it, mails log to console
# RESEND_API_KEY=
# MAIL_FROM="EduSentinel AI <no-reply@edusentinel.ai>"
# Second-channel alerts for privileged events (role changes, publishes, revocations)
# ALERT_EMAIL=

# --- Phase 3: release signing & scanning ---
# ed25519 private key (base64 PKCS8). Generate:
#   node -e "const{generateKeyPairSync}=require('crypto');const{privateKey,publicKey}=generateKeyPairSync('ed25519');console.log(privateKey.export({type:'pkcs8',format:'der'}).toString('base64'));require('fs').writeFileSync('public/signing-key.pem',publicKey.export({type:'spki',format:'pem'}))"
# The matching public key must be served at /signing-key.pem for users to verify downloads.
SIGNING_PRIVATE_KEY=""
# Optional malware scanning (else artifacts report NO_SCANNER — see SECURITY-NOTES SN-005)
# VIRUSTOTAL_API_KEY=

# Optional: founder bootstrap for `npm run db:seed`
# FOUNDER_EMAIL=
# FOUNDER_NAME=
# FOUNDER_PASSWORD=   (min. 10 characters)
