// EduSentinel identity schema — Phase 2 + 2.1 (auth hardening).
// Dev runs on SQLite for zero-setup; production switches provider to
// "postgresql" (managed Postgres per the approved architecture) — the
// schema is written to be portable. Role is a string because SQLite has
// no enums; valid values (Phase 5 ladder, low to high):
// USER | COLLABORATOR | EMPLOYEE | ADMIN | CO_FOUNDER | FOUNDER — enforced in
// src/lib/roles.ts, src/lib/authz.ts and src/lib/permissions.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  name           String
  passwordHash   String
  role           String      @default("USER")
  emailVerified  DateTime?
  mfaEnabled     Boolean     @default(false)
  totpSecret     String? // AES-256-GCM encrypted (never plaintext)
  failedLogins   Int         @default(0)
  lockedUntil    DateTime?
  sessionVersion Int         @default(0) // bump = revoke all sessions
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  authTokens     AuthToken[]

  // ---- Phase 6.2: profile ----
  // Self-service for every role. Free text is sanitized on write (lib/sanitize.ts)
  // and rendered as plain text — a display name reaches the directory, the message
  // center and CSV exports, so it is treated as untrusted like any other input.
  //
  // The avatar is a FILE, therefore a threat: `avatarName` is a generated name in
  // storage/avatars (outside the web root), never the uploaded filename, and the
  // bytes are magic-byte validated and stripped of metadata before they land
  // (lib/images.ts). Only PNG and JPEG — SVG is script.
  title          String?
  bio            String?
  pronouns       String?
  timezone       String?
  location       String?
  phone          String? // internal contact; never shown to collaborators
  avatarName     String? // generated storage name
  avatarMime     String?
  avatarAt       DateTime? // cache-buster for the avatar route

  // Presence. Stamped by the workspace shell, throttled — the "Team Online" rail
  // used to hard-code everyone as online, which was decoration, not data.
  lastSeenAt     DateTime?

  // Notification preferences (Phase 9 consumes these; the profile owns them).
  // Security-critical mail is deliberately NOT optional and has no flag here.
  notifyDigest   Boolean     @default(true)
  notifyMentions Boolean     @default(true)
  notifyProduct  Boolean     @default(false)
  // Phase 5
  grants         PermissionGrant[] @relation("grantee")
  memberships    TeamMember[]      @relation("membership")
  tasks          Task[]            @relation("assignee")
  // Phase 5.3
  conversations  ConversationParticipant[] @relation("participant")
  messages       Message[]                 @relation("author")
  // Phase 6.5 — the org chart and the collaboration relationship, if any.
  // Both are optional: an account is not an org member, and an org member is not
  // necessarily an account.
  orgMember      OrgMember?
  collaboration  Collaboration?
  // Phase 8 — workforce. Sensitive personal data; always read through lib/hr.ts.
  attendance     Attendance[]   @relation("attendance")
  leaveBalances  LeaveBalance[] @relation("leaveBalance")
  leaveRequests  LeaveRequest[] @relation("leaveRequest")
  // Phase 9 — support & notifications.
  supportRaised   SupportRequest[] @relation("supportRequester")
  supportAssigned SupportRequest[] @relation("supportAssignee")
  supportMessages SupportMessage[] @relation("supportAuthor")
  notifications   Notification[]   @relation("notified")
}

// Single-use expiring tokens for email verification and password reset.
// Only the SHA-256 hash of the token is stored.
model AuthToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  type      String // "verify-email" | "reset-password"
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, type])
}

// Append-only and INDEPENDENT of the users table — deliberately no foreign key
// to User.
//
// It used to have one (`actor User? @relation`). Prisma's default onDelete for an
// optional relation is SetNull, so deleting an account rewrote actorId to null on
// that account's audit rows — and because the hash commits to actorId, routine
// offboarding or an erasure request silently broke the R7b chain and looked
// exactly like tampering. An audit log cannot be mutable as a side effect of
// activity elsewhere in the schema.
//
// The actor is therefore SNAPSHOT here (id + email as they were at the time),
// which is also what an audit record should hold: what was true when the event
// happened, not a join to a row someone can later change or delete.
model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g. user.signup, user.login, user.login_failed, admin.role_change
  detail     String?
  ip         String?
  userAgent  String?
  actorId    String? // no FK: the log outlives the account
  actorEmail String? // snapshot for display; never joined
  createdAt  DateTime @default(now())
  // R7b: tamper-evident hash chain — each row commits to its predecessor.
  prevHash   String?
  hash       String?

  @@index([createdAt])
  @@index([actorId])
}

// ---------- Phase 3: product registry & release pipeline ----------

// A product is the catalogue record AND the release container. Phase 5.5 adds
// the marketing fields so the Founder can add a new EduSentinel product from the
// dashboard and have it appear across the public site with no code change.
//
// `icon` is a KEY into a fixed icon set (lib/product-icons.tsx) — never raw SVG
// or HTML. Founder-authored text is sanitized on write and rendered as plain
// text, exactly like public submissions: the dashboard is trusted, but the
// public site is not the place to discover we were wrong about that.
// `tags`/`features` are JSON string arrays (SQLite has no array type).
model Product {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  ownerId     String // R12: every product has an owner; queries are ownership-scoped
  createdAt   DateTime  @default(now())
  releases    Release[]

  // ---- catalogue / marketing (Phase 5.5) ----
  status      String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  tagline     String? // one-line summary for cards
  icon        String    @default("shield") // key into the fixed icon set
  pricing     String    @default("free") // free | paid | soon  (badge tone)
  tags        String    @default("[]") // JSON string[]
  features    String    @default("[]") // JSON string[]
  ctaLabel    String    @default("Get notified")
  ctaHref     String    @default("/contact") // internal path or https URL only
  sortOrder   Int       @default(0)
  featured    Boolean   @default(false)
  publishedAt DateTime?
  archivedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([status, sortOrder])
}

// Release lifecycle: QUARANTINED -> (scan/review) -> PUBLISHED | REJECTED -> REVOKED
model Release {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  version      String
  notes        String?
  status       String    @default("QUARANTINED") // QUARANTINED | PUBLISHED | REJECTED | REVOKED
  createdById  String
  createdAt    DateTime  @default(now())
  publishedAt  DateTime?
  revokedAt    DateTime?
  revokeReason String?
  artifact     Artifact?

  @@unique([productId, version])
}

// ---------- Phase 4: collaboration requests & abuse reports ----------

// Public submissions. Text is sanitized on write (never trusted on read).
model CollaborationRequest {
  id         String    @id @default(cuid())
  name       String
  email      String
  org        String?
  kind       String // partnership | contributor | research | other
  message    String
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED | SPAM
  ip         String?
  reviewedAt DateTime?
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
}

// Abuse reports against collaboration submissions or published content.
model AbuseReport {
  id         String    @id @default(cuid())
  targetType String // collaboration | release | other
  targetRef  String? // id or URL of the reported item
  reason     String
  reporter   String? // optional contact
  status     String    @default("OPEN") // OPEN | ACTIONED | DISMISSED
  ip         String?
  handledAt  DateTime?
  handledBy  String?
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
}

// ---------- Phase 5: capability grants, teams & workload ----------

// Per-person capability override on top of the role default set.
// allow=true grants, allow=false revokes. Founder-reserved capabilities are
// rejected at write time and stripped at read time (src/lib/permissions.ts) —
// a row here can never escalate anyone.
model PermissionGrant {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation("grantee", fields: [userId], references: [id], onDelete: Cascade)
  capability String
  allow      Boolean   @default(true)
  grantedBy  String // Founder's user id
  reason     String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@unique([userId, capability])
  @@index([userId])
}

model Team {
  id           String       @id @default(cuid())
  name         String       @unique
  description  String?
  createdAt    DateTime     @default(now())
  members      TeamMember[]
  projects     Project[]
  // Phase 6.5: teams sit inside departments on the org chart.
  departmentId String?
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  orgMembers   OrgMember[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation("membership", fields: [userId], references: [id], onDelete: Cascade)
  title    String? // display role within the team, e.g. "DevOps Engineer"
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  progress  Int      @default(0) // 0-100, drives the reference's progress bars
  status    String   @default("ACTIVE") // ACTIVE | PAUSED | DONE
  createdAt DateTime @default(now())
  tasks     Task[]

  @@index([teamId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  detail      String?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?     @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      String    @default("OPEN") // OPEN | IN_PROGRESS | DONE
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH
  dueAt       DateTime?
  createdAt   DateTime  @default(now())

  @@index([assigneeId, status])
}

// ---------- Phase 5.3: message center ----------

// A conversation is the unit of access control: you see a thread only if you
// are a participant. `kind` mirrors the reference's Team / Client tabs —
// TEAM threads are internal, COLLAB threads include an external collaborator
// (and therefore must never carry internal-only chatter by construction:
// participants are explicit, never implied by role).
model Conversation {
  id           String                    @id @default(cuid())
  kind         String                    @default("TEAM") // TEAM | COLLAB
  subject      String?
  createdById  String
  createdAt    DateTime                  @default(now())
  lastMessageAt DateTime                 @default(now())
  participants ConversationParticipant[]
  messages     Message[]

  @@index([kind, lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("participant", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

// Body is sanitized on write (lib/sanitize.ts) and rendered as plain text only —
// never MDX, never HTML. Same rule as public submissions (Phase 4).
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation("author", fields: [authorId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ---------- Phase 9: support & notifications ----------

// A service request. The requester is the unit of access control, exactly as the
// conversation is in the message center (Phase 5.3): you see a request if you
// RAISED it, or if you hold `support.respond`. There is no unscoped "get by id".
//
// A collaborator may raise a request and reach staff. They can never see another
// collaborator's request — we do not become a channel between external parties,
// which is the same rule the message center is built on.
//
// Bodies are sanitized on write and rendered as PLAIN TEXT ONLY. A support request
// is public-supplied text arriving in a staff console; treating it as anything
// else is how a support inbox becomes a stored-XSS delivery mechanism.
model SupportRequest {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("supportRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  subject     String
  category    String   @default("other") // access | bug | billing | security | other
  priority    String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  assigneeId  String?
  assignee    User?    @relation("supportAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  // SLA is measured, not promised: firstResponseAt and resolvedAt are stamped when
  // they actually happen, so "we respond within a day" is a number we can check
  // rather than a claim on a page.
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    SupportMessage[]
  attachments SupportAttachment[]

  @@index([status, createdAt])
  @@index([requesterId])
}

model SupportMessage {
  id        String         @id @default(cuid())
  requestId String
  request   SupportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation("supportAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String // sanitized on write; plain text only
  // An internal note is staff-only: it is never returned to the requester by the
  // query helpers, so a reply can be discussed without the discussion leaking.
  internal  Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@index([requestId, createdAt])
}

// Attachments go through the SAME upload gates as release artifacts and avatars:
// magic-byte validation (never the filename or claimed MIME), a size cap, storage
// outside the web root under a generated name, and an authenticated,
// participant-scoped route to read them back. No SVG — it is script.
model SupportAttachment {
  id          String         @id @default(cuid())
  requestId   String
  request     SupportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedById String
  fileName    String // original name, display only
  storageName String         @unique // generated name on disk
  mime        String
  size        Int
  createdAt   DateTime       @default(now())

  @@index([requestId])
}

// One notification, for one person.
//
// Notifications are GENERATED BY REAL DOMAIN EVENTS — a leave request awaiting
// you, a support reply, an invitation accepted. Never by a timer that invents
// them, and never containing anything the recipient could not already open: the
// payload is a title, a line of context, and a link that RE-CHECKS server-side.
// Nothing sensitive travels in a notification (see lib/notifications.ts).
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("notified", fields: [userId], references: [id], onDelete: Cascade)
  kind      String // leave.pending | leave.decided | support.replied | …
  title     String
  body      String?
  href      String? // internal /app path only — validated on write
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ---------- Phase 8: HR & workforce ----------
//
// Attendance and leave are SENSITIVE PERSONAL DATA. Two rules run through every
// model below and through lib/hr.ts:
//
//   1. Visibility is scoped BY RELATIONSHIP — self, approver, HR, founder. There
//      is no "all employees" read anywhere outside a capability-gated helper.
//   2. A LEAVE REASON IS READABLE ONLY BY THE PERSON AND THEIR APPROVER CHAIN. It
//      is the field most likely to hold a medical fact ("hospital appointment"),
//      and it never appears on a team calendar, in an export, or in a
//      notification. `LeaveRequest.reason` is stripped by the query helpers for
//      anyone else — see redactLeave().
//
// Retention: attendance and leave rows are kept for 24 months after the period
// they describe (SECURITY-NOTES). Nothing here is kept "just in case".

// One row per person per day. `date` is midnight UTC — a day, not an instant, so
// two clock-ins on the same day cannot create two days.
model Attendance {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("attendance", fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime // midnight UTC of the day this record describes
  status    String    @default("WORKING") // WORKING | REMOTE | SICK | ABSENT | LEAVE | HOLIDAY
  clockIn   DateTime?
  clockOut  DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  corrections AttendanceCorrection[]

  @@unique([userId, date])
  @@index([date])
}

// A correction is REQUESTED and APPROVED — never applied silently.
//
// An attendance record that anyone can quietly rewrite is worthless as a record:
// it becomes a claim about the past with no author. So the old value, the proposed
// value, the person who asked and the person who decided are all kept, and the
// change only lands when someone with `attendance.manage` says so.
model AttendanceCorrection {
  id           String     @id @default(cuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  requestedById String
  fromStatus   String
  toStatus     String
  reason       String
  status       String     @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedById  String?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime   @default(now())

  @@index([status, createdAt])
}

model LeaveType {
  id           String         @id @default(cuid())
  name         String         @unique
  code         String         @unique // ANNUAL | SICK | UNPAID | …
  defaultDays  Int            @default(0) // starting entitlement per year
  paid         Boolean        @default(true)
  color        String         @default("cyan") // token key, never a raw hex
  active       Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  balances     LeaveBalance[]
  requests     LeaveRequest[]
}

model LeaveBalance {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("leaveBalance", fields: [userId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year        Int
  entitled    Float     @default(0)
  // Days spent by APPROVED leave. A pending request does not spend a balance, but
  // it is counted as *pending* so someone cannot queue five overlapping requests
  // against one day of entitlement.
  used        Float     @default(0)
  pending     Float     @default(0)

  @@unique([userId, leaveTypeId, year])
  @@index([userId, year])
}

model LeaveRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("leaveRequest", fields: [userId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  // Working days actually charged: weekends and public holidays inside the range
  // are NOT charged (lib/hr.ts). Booking five days across a bank holiday must not
  // cost five days of someone's entitlement.
  days        Float
  // The most sensitive field in the schema. Readable only by the requester and
  // their approver chain — stripped everywhere else by redactLeave().
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?
  createdAt   DateTime  @default(now())

  @@index([status, startDate])
  @@index([userId, startDate])
}

// Company holidays. Feed the leave maths and the team calendar.
model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime // midnight UTC
  region    String? // null = everyone
  createdAt DateTime @default(now())

  @@unique([date, region])
  @@index([date])
}

// ---------- Phase 7: invitations, mail, access review ----------

// How a person joins EduSentinel.
//
// The offer IS the access decision: the role (and, from the Founder, the starting
// capabilities) are chosen at invitation time, made once and audited — not a
// signup followed by a scramble to promote someone.
//
// The token is stored ONLY as a SHA-256 hash, exactly like AuthToken (R9): the
// plaintext exists in the email and nowhere else, so a database leak cannot be
// replayed into an account. Single-use and expiring.
//
// FOUNDER and CO_FOUNDER are not invitable (lib/invitations.ts). An invitation
// cannot mint privilege at or above the inviter, and can never mint a Founder —
// the Trust Model closes that door before the feature exists rather than after.
model Invitation {
  id            String    @id @default(cuid())
  email         String
  tokenHash     String    @unique
  role          String // the role granted on acceptance
  capabilities  String    @default("[]") // JSON string[] — founder-issued starting grants
  status        String    @default("PENDING") // PENDING | ACCEPTED | REVOKED
  message       String?
  invitedById   String
  invitedByEmail String // snapshot, like the audit log: it outlives the account
  expiresAt     DateTime
  acceptedAt    DateTime?
  acceptedById  String?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, createdAt])
  @@index([email])
}

// Mail we tried to send. A failed invitation that vanishes into a log file is an
// invitation the Founder thinks they sent — so delivery outcomes are records, and
// they surface in the workspace.
//
// The BODY IS NOT STORED. It would put password-reset and invitation links —
// live credentials, in effect — in a table that is not treated as one. Subject and
// outcome are enough to answer "did it go?".
model MailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  kind      String // invitation | verify-email | reset-password | alert | notice
  status    String // SENT | FAILED | DEV_OUTBOX
  error     String?
  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

// Quarterly access review (Continuous Security Track, given a surface).
// The Founder is shown everyone holding elevated capability and confirms or
// revokes — on the record, so "we review access quarterly" is a fact with rows
// behind it rather than a claim in a policy document.
model AccessReview {
  id          String   @id @default(cuid())
  reviewerId  String
  reviewedAt  DateTime @default(now())
  accounts    Int // how many elevated accounts were in scope
  revoked     Int // how many grants the review removed
  note        String?

  @@index([reviewedAt])
}

// ---------- Phase 6.5: organization & company ----------

// The company itself, as a record. Exactly one row (id = "company"): a singleton
// rather than a settings key-value bag, so the shape is typed and a typo cannot
// invent a new setting. Read by the marketing site, the footer and the page
// metadata — change it here and it changes everywhere, because there is nowhere
// else it is stored.
//
// The logo is an UPLOAD, so it goes through lib/images.ts like every other file a
// human hands us: magic-byte validated, size-capped, metadata-stripped, no SVG.
model CompanyProfile {
  id          String   @id @default("company")
  name        String   @default("EduSentinel AI")
  legalName   String?
  tagline     String?
  description String?
  email       String?
  phone       String?
  address     String?
  website     String?
  founded     String?
  links       String   @default("[]") // JSON [{label, href}] — href is https-only (safeHref)
  logoName    String? // generated name in storage/brand
  logoMime    String?
  logoAt      DateTime?
  updatedAt   DateTime @updatedAt
}

model Department {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  members     OrgMember[]
  teams       Team[]
}

// A person's place in the ORGANIZATION — which is not the same thing as their
// account, and must not be confused with it:
//
//   User       = who can sign in, and what they may do (Phases 2, 5, 6).
//   OrgMember  = who they are ON THE ORG CHART: designation, department, order,
//                whether the public sees them.
//
// An advisor or investor has an OrgMember row and no account at all. An engineer
// has both.
//
// SINGLE SOURCE OF TRUTH: when `userId` is set, the person's name, email and photo
// RESOLVE FROM THE USER PROFILE (lib/org.ts) — this row does not keep a second
// copy, because two copies of a name is one name that will be wrong. The `name`,
// `email`, `phone` and photo columns here are used only for members with no
// account, and are ignored when a link exists.
//
// `designation` is free text, not an enum: a fixed list of job titles is a guess
// about a company that does not exist yet. Suggestions are offered in the UI.
model OrgMember {
  id           String      @id @default(cuid())
  userId       String?     @unique // linked account, if this person has one
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String // fallback identity for unlinked members (advisors, investors)
  email        String?
  phone        String?
  designation  String // "Founder", "CISO", "Investor", or anything the Founder types
  bio          String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  teamId       String?
  team         Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  links        String      @default("[]") // JSON [{label, href}] — https only
  photoName    String? // uploaded photo; used only when there is no linked account
  photoMime    String?
  photoAt      DateTime?
  // A photo that ships in public/ as a build asset (the team portraits the site
  // launched with). Not an upload, so it is not in storage/ and does not go
  // through /api/photo — it is served straight from the public folder. Lowest
  // precedence: a linked account's avatar wins, then an upload, then this.
  photoPath    String?
  sortOrder    Int         @default(0)
  visibility   String      @default("INTERNAL") // PUBLIC | INTERNAL | HIDDEN
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([visibility, sortOrder])
}

// The missing model, and the reason the Collaboration page could be empty while
// People listed collaborators.
//
// `User(role: COLLABORATOR)` is an ACCOUNT. `CollaborationRequest` is a public
// SUBMISSION. Neither of them is the relationship — and it was the relationship
// the Founder wanted to manage. This row is that relationship: it may be linked to
// the account, to the request it grew out of, both, or neither (a partnership that
// started over a call and never touched the public form).
model Collaboration {
  id        String    @id @default(cuid())
  userId    String?   @unique // the collaborator's account, when they have one
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  requestId String?   @unique // the public request it came from, when it did
  name      String
  org       String?
  email     String?
  kind      String    @default("partnership") // partnership | contributor | research | other
  status    String    @default("ACTIVE") // ACTIVE | PAUSED | ENDED
  summary   String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, startedAt])
}

model Artifact {
  id            String  @id @default(cuid())
  releaseId     String  @unique
  release       Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  fileName      String // original name, display only
  storageName   String  @unique // generated name on disk (storage/ outside web root)
  size          Int
  mime          String
  sha256        String
  signature     String? // ed25519 over sha256, set at publish (founder-gated)
  scanStatus    String  @default("PENDING") // PENDING | CLEAN | FLAGGED | NO_SCANNER
  scanDetail    String?
  downloadCount Int     @default(0)
}
